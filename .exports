#!/usr/bin/env bash

# Make vim the default editor.
export EDITOR='vim';

# Enable persistent REPL history for `node`.
export NODE_REPL_HISTORY=~/.node_history;
# Allow 32³ entries; the default is 1000.
export NODE_REPL_HISTORY_SIZE='32768';
# Use sloppy mode by default, matching web browsers.
export NODE_REPL_MODE='sloppy';

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

# Make Python use UTF-8 encoding for output to stdin, stdout, and stderr.
export PYTHONIOENCODING='UTF-8';

# Increase Bash history size. Allow 32³ entries; the default is 500.
export HISTSIZE='32768';
export HISTFILESIZE="${HISTSIZE}";
# Omit duplicates and commands that begin with a space from history.
export HISTCONTROL='ignoreboth';

# Prefer US English and use UTF-8.
export LANG='en_US.UTF-8';
export LC_ALL='en_US.UTF-8';

# Highlight section titles in manual pages.
export LESS_TERMCAP_md="${yellow}";

# Don’t clear the screen after quitting a manual page.
export MANPAGER='less -X';

# Avoid issues with `gpg` as installed via Homebrew.
# https://stackoverflow.com/a/42265848/96656
export GPG_TTY=$(tty);

# RBenv homebrew
eval "$(rbenv init -)"

# ruby-build installs a non-Homebrew OpenSSL for each Ruby version installed and these are never upgraded.
# To link Rubies to Homebrew's OpenSSL 1.1 (which is upgraded) add the following
export RUBY_CONFIGURE_OPTS="--with-openssl-dir=$(brew --prefix openssl@1.1)"

export DOTNET_CLI_TELEMETRY_OPTOUT='true'
# export CHROME_EXECUTABLE="/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"
export OP_BIOMETRIC_UNLOCK_ENABLED=true

export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock

export FASTLANE_SESSION='---\n- !ruby/object:HTTP::Cookie\n  name: myacinfo\n  value: \n  domain: apple.com\n  for_domain: true\n  path: "/"\n  secure: true\n  httponly: true\n  expires:\n  max_age:\n  created_at: 2024-06-04 19:13:24.909645000 +02:00\n  accessed_at: 2024-06-04 19:13:24.912307000 +02:00\n- !ruby/object:HTTP::Cookie\n  name: DES5c303d80e1ff6597d06440f37ea3cff2b\n  value: HSARMTKNSRVXWFlaoSK6BwuDs8/o7NAYR9QcbIG9viQNR07Um9yvVnuHyDzL/Odhg7H1vlIuIydDBDosB+LipwuMlHq6zhBd231qCJJAM/nRwE+pEelnS1a5KYxUMUM6CduzH8AANQ42cdLhIUILjND1apicAJSZ8W+IB78w/ROvu4SmGeOP1OpWm8r1SkxwALfYZkG4KYl1XhfBt7VayjC8OaZU7489MXWGSRVX\n  domain: idmsa.apple.com\n  for_domain: true\n  path: "/"\n  secure: true\n  httponly: true\n  expires:\n  max_age: 2592000\n  created_at: &1 2024-06-04 19:13:24.909605000 +02:00\n  accessed_at: *1\n- !ruby/object:HTTP::Cookie\n  name: dqsid\n  value: eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpYXQiOjE3MTc1MjEyMDUsImp0aSI6IlNyWVBnVHctWHFLZmpMX3Z1ZnVTa3cifQ.Z7FdrxGHoG-zQL5r-na7AHuIrMohCzR0nbJRaTE3GvE\n  domain: appstoreconnect.apple.com\n  for_domain: false\n  path: "/"\n  secure: true\n  httponly: true\n  expires:\n  max_age: 1800\n  created_at: &2 2024-06-04 19:13:26.081455000 +02:00\n  accessed_at: *2\n'

export KUBECONFIG=~/.kube/config-scaleway-learning-apps.yaml:~/.kube/config-ovh-vega.yml:~/.kube/config-ovh-pocketable.yml